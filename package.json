{
  "name": "@opentui",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/solid/examples"
  ],
  "scripts": {
    "build": "cd packages/core && bun run build && cd ../solid && bun run build && cd ../react && bun run build && cd ../extras && bun run build",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:ci": "oxlint . --deny-warnings",
    "lint:fix": "oxlint --fix .",
    "pre-publish": "bun scripts/pre-publish.ts",
    "publish": "bun run pre-publish && bun run publish:core && bun run publish:react && bun run publish:solid && bun run publish:extras",
    "publish:core": "cd packages/core && bun run publish",
    "publish:react": "cd packages/react && bun run publish",
    "publish:solid": "cd packages/solid && bun run publish",
    "publish:extras": "cd packages/extras && bun run publish",
    "prepare-release": "bun scripts/prepare-release.ts",
    "test": "bun run --filter '@opentui/core' --filter '@opentui/solid' --filter '@opentui/react' --filter '@opentui/extras' --if-present test"
  },
  "devDependencies": {
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0"
  }
}
