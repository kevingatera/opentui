{
  "name": "@opentui/extras",
  "version": "0.1.99",
  "description": "Standalone extras package for OpenTUI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anomalyco/opentui",
    "directory": "packages/extras"
  },
  "module": "index.ts",
  "type": "module",
  "private": true,
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.ts"
    },
    "./keymap": {
      "import": "./keymap/index.ts",
      "types": "./keymap/index.ts"
    }
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "publish": "bun run scripts/publish.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@opentui/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.0.0",
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
